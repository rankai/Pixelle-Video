{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixelle://contracts/app-center/artifact-contract.v1.schema.json",
  "title": "Pixelle Artifact and ArtifactVersion",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "project_id", "artifact_type", "current_version_id", "versions"],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "artifact_type": {
      "enum": ["brief", "copywriting", "title_set", "selected_title", "carousel_plan", "carousel_page", "carousel_package", "video", "cover", "publish_copy", "publish_package_ref"]
    },
    "current_version_id": { "type": "string", "minLength": 1 },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_version_id", "revision", "schema_version", "content", "created_at"],
        "properties": {
          "artifact_version_id": { "type": "string", "minLength": 1 },
          "revision": { "type": "integer", "minimum": 1 },
          "schema_version": { "const": 1 },
          "content": { "type": "object" },
          "media_refs": { "type": "array", "items": { "type": "object" } },
          "created_at": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

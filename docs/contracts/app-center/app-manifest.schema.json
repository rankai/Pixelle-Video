{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixelle://contracts/app-center/app-manifest.v1.schema.json",
  "title": "Pixelle Application Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "app_id",
    "version",
    "name",
    "description",
    "category",
    "status",
    "icon",
    "executor_type",
    "executor_key",
    "input_schema",
    "output_schema",
    "required_capabilities",
    "accepted_artifact_types",
    "produced_artifact_types",
    "handoff_targets",
    "feature_flag",
    "sort_order"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "app_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "pilot", "stable", "maintenance", "disabled", "retired"] },
    "icon": { "enum": ["FilePenLine", "BadgeCheck", "Images", "Video"] },
    "executor_type": { "enum": ["structured_llm", "document_render", "workflow_adapter"] },
    "executor_key": { "enum": ["marketing_copy_v1", "viral_titles_v1", "douyin_carousel_v1", "digital_human_video_v1"] },
    "input_schema": { "type": "string", "minLength": 1 },
    "output_schema": { "type": "string", "minLength": 1 },
    "required_capabilities": { "type": "array", "items": { "enum": ["llm", "template", "runninghub", "digital_human"] }, "uniqueItems": true },
    "accepted_artifact_types": { "type": "array", "items": { "enum": ["brief", "copywriting", "title_set", "selected_title", "carousel_plan", "carousel_page", "carousel_package", "video", "cover", "publish_copy", "publish_package_ref"] }, "uniqueItems": true },
    "produced_artifact_types": { "type": "array", "items": { "enum": ["brief", "copywriting", "title_set", "selected_title", "carousel_plan", "carousel_page", "carousel_package", "video", "cover", "publish_copy", "publish_package_ref"] }, "uniqueItems": true },
    "handoff_targets": { "type": "array", "items": { "enum": ["builtin.marketing-copy", "builtin.viral-titles", "builtin.douyin-carousel", "builtin.digital-human-video"] }, "uniqueItems": true },
    "feature_flag": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
    "sort_order": { "type": "integer", "minimum": 0 }
  }
}

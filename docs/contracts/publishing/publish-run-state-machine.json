{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pixelle://contracts/publishing/publish-run-state-machine.v1.json",
  "title": "PublishRun state machine",
  "type": "object",
  "additionalProperties": false,
  "required": ["states", "transitions", "terminal_states", "human_confirmation_required", "transition_guards"],
  "properties": {
    "states": {
      "type": "array",
      "items": { "enum": ["queued", "running", "waiting_for_login", "waiting_for_human", "needs_attention", "succeeded", "failed", "cancelled"] },
      "uniqueItems": true
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    },
    "terminal_states": {
      "type": "array",
      "items": { "enum": ["succeeded", "failed", "cancelled"] },
      "uniqueItems": true
    },
    "human_confirmation_required": { "const": true },
    "transition_guards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "requires"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "requires": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
        }
      }
    },
    "final_publish_action": { "const": "never_exposed" }
  }
}
